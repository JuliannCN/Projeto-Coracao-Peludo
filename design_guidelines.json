{
  "theme": "light",
  "archetype": "3 (Pastel & Soft) with Neo-Brutalist contrast",
  "colors": {
    "background_primary": "#FAFAFA",
    "background_secondary": "#F3EFFF",
    "primary_cta": "#5A3E85",
    "primary_cta_hover": "#452C69",
    "accent": "#FFC499",
    "text_main": "#1C1724",
    "text_muted": "#564F62",
    "border_subtle": "#E4DDF1",
    "border_hard": "#1C1724"
  },
  "typography": {
    "heading_font": "Outfit",
    "body_font": "Figtree",
    "h1": "text-4xl sm:text-5xl lg:text-6xl font-black tracking-tight leading-none",
    "h2": "text-2xl sm:text-3xl lg:text-4xl font-bold tracking-tight",
    "h3": "text-xl sm:text-2xl font-semibold",
    "body": "text-base leading-relaxed font-medium",
    "overline": "text-xs font-bold uppercase tracking-[0.2em]"
  },
  "layout_spacing": {
    "container_padding": "p-8 md:p-12 lg:p-16",
    "bento_gap": "gap-6 md:gap-8",
    "card_padding": "p-6",
    "border_radius": "rounded-3xl",
    "inner_radius": "rounded-2xl"
  },
  "surfaces": {
    "glass_header": "backdrop-blur-xl bg-white/70 border-b border-black/5 shadow-sm z-50",
    "pet_card": "bg-white border border-[#E4DDF1] shadow-sm hover:shadow-lg hover:-translate-y-1 transition-all duration-300 rounded-3xl overflow-hidden flex flex-col",
    "dashboard_panel": "bg-white border border-[#E4DDF1] rounded-2xl p-6",
    "forum_post": "bg-[#FAFAFA] border border-[#E4DDF1] rounded-2xl p-6 hover:border-[#5A3E85] transition-colors"
  },
  "motion_interactions": {
    "hover_lift": "transition-transform duration-300 hover:-translate-y-1",
    "focus_state": "focus:outline-none focus:ring-2 focus:ring-[#5A3E85] focus:ring-offset-2",
    "button_active": "active:scale-95 transition-transform"
  },
  "components": {
    "button_primary": "bg-[#5A3E85] text-white font-bold py-3 px-6 rounded-full hover:bg-[#452C69] hover:text-white transition-colors flex items-center justify-center gap-2",
    "button_secondary": "bg-[#F3EFFF] text-[#5A3E85] font-bold py-3 px-6 rounded-full hover:bg-[#E4DDF1] hover:text-[#452C69] transition-colors",
    "badge": "bg-[#FFC499] text-[#1C1724] text-xs font-bold px-3 py-1 rounded-full uppercase tracking-wider"
  },
  "icon_strategy": {
    "library": "lucide-react",
    "style": "stroke-width: 2.5, clean and geometric"
  },
